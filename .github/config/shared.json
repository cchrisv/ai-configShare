{
  "organization": "UMGC",
  "project": "Digital Platforms",
  "wiki": {
    "name": "Digital Platforms Wiki",
    "base_url": "https://dev.azure.com/UMGC/Digital%20Platforms/_wiki/wikis/Digital%20Platforms%20Wiki",
    "parent_path": "CRM-Home/Legacy-Org",
    "object_path_format": "CRM-Home/Legacy-Org/{object}/{work_item_id}-{title_slug}"
  },
  "workflow": {
    "phases": [
      "research",
      "grooming",
      "solutioning",
      "wiki",
      "finalization"
    ],
    "artifacts_root": ".ai-artifacts/{work_item_id}",
    "unified_context_file": "ticket-context.json",
    "unified_context_schema": "#file:.github/templates/ticket-context-schema.json",
    "phase_outputs": {
      "description": "Files generated by each phase. ticket-context.json is progressively updated by all phases.",
      "all_phases": ["ticket-context.json"],
      "solutioning": ["solution-summary.md"],
      "wiki": ["wiki-content.md"]
    },
    "legacy_phase_artifacts": {
      "description": "Legacy artifact structure for migration reference. Deprecated - use unified context file.",
      "research": [
        "01-ado-workitem.json",
        "02-wiki-search.json",
        "02-business-context.json",
        "journey-process-maps.json",
        "03-salesforce-metadata.json",
        "03a-dependency-discovery.json",
        "04-code-search.json",
        "05-web-research.json",
        "06-context7-libraries.json",
        "07-similar-workitems.json",
        "assumptions.json"
      ],
      "grooming": [
        "classification.json",
        "templates-applied.json"
      ],
      "solutioning": [
        "solution-output.json"
      ],
      "wiki": [
        "wiki-creation.json"
      ],
      "finalization": [
        "context-snapshot.json"
      ]
    }
  },
  "template_variables": {
    "file": "#file:.github/config/template-variables.json",
    "schema": "#file:.github/config/template-variables.schema.json"
  },
  "flow_health": {
    "description": "Accelerated flow health thresholds (50% faster than traditional timelines)",
    "warning_days": 3,
    "critical_days": 7,
    "escalation_days": 10,
    "churn_reassignments": 2,
    "churn_window_days": 5,
    "silent_days": 5,
    "cascade_complete_percent": 70,
    "severity_indicators": {
      "warning": "⚠️",
      "critical": "🔴",
      "escalation": "🚨",
      "attention": "🟡",
      "cleared": "✅",
      "action": "🎯",
      "progress": "📊",
      "planned": "📋",
      "immediate": "🎯",
      "nearterm": "📅",
      "upcoming": "🔮"
    }
  },
  "step_manifests": {
    "file": "#file:.github/config/step-manifests.json",
    "schema": "#file:.github/config/step-manifests.schema.json"
  },
  "templatized_workflow": {
    "file": "#file:.github/config/templatized-workflow.json",
    "schema": "#file:.github/config/templatized-workflow.schema.json"
  },
  "quality_bar": {
    "gates": [
      {
        "name": "solutionLeak",
        "phase": "grooming",
        "description": "Ensure requirements contain WHAT/WHY only."
      },
      {
        "name": "clarity",
        "phase": "grooming",
        "description": "Verify business-focused language and persona coverage."
      },
      {
        "name": "testability",
        "phase": "grooming",
        "description": "Validate Given/When/Then acceptance criteria with edge cases."
      },
      {
        "name": "logicalFallacy",
        "phase": "grooming",
        "description": "Detect and challenge logical fallacies in requirements."
      },
      {
        "name": "completeness",
        "phase": "grooming",
        "description": "Ensure critical unknowns are identified and documented."
      },
      {
        "name": "traceability",
        "phase": "solutioning",
        "description": "Map ACs to solution elements and telemetry events."
      },
      {
        "name": "safety",
        "phase": "solutioning",
        "description": "Assess PII/FERPA, environment constraints, and rollback plans."
      },
      {
        "name": "unknowns",
        "phase": "solutioning",
        "description": "Document critical technical unknowns with impact and who can clarify."
      }
    ]
  },
  "tags": {
    "refined": "CoPilot-Refined",
    "solutioned": "CoPilot-Solutioned",
    "expedite": "Expedite",
    "wsjf_blocker": "WSJF-Blocker"
  },
  "templates": {
    "user_story": "#file:.github/templates/user-story-templates.md",
    "bug": "#file:.github/templates/bug-templates.md",
    "audit_task": "#file:.github/templates/audit-task-template.md",
    "comment_formats": "#file:.github/templates/comment-formats.md",
    "wiki_format": "#file:.github/templates/wiki-page-format.md",
    "validation_checklist": "#file:.github/templates/validation-checklist.md",
    "test_case": "#file:.github/templates/test-case-template.md"
  },
  "standards": {
    "apex": "#file:.github/standards/apex-well-architected.md",
    "flows": "#file:.github/standards/flow-well-architected.md",
    "flow_naming": "#file:.github/standards/flow-naming-conventions.md",
    "flow_subflow": "#file:.github/standards/flow-subflow-usage.md",
    "lwc": "#file:.github/standards/lwc-well-architected.md",
    "triggers": "#file:.github/standards/trigger-actions-framework-standards.md",
    "metadata_naming": "#file:.github/standards/metadata-naming-conventions.md",
    "logging": "#file:.github/standards/nebula-logger-standards.md",
    "feature_flags": "#file:.github/standards/feature-flags-standards.md",
    "code_complexity": "#file:.github/standards/code-complexity-standards.md"
  },
  "scripts": {
    "metadata_dependencies": ".github/scripts/discover-metadata-dependencies.cjs",
    "metadata_dependencies_lib": ".github/scripts/lib/index.cjs"
  },
  "metadata_dependencies_options": {
    "description": "Enhanced dependency discovery options ported from sfdc-soup patterns",
    "default_options": {
      "depth": 5,
      "enrich": true,
      "includeStandardFields": true,
      "includeCMTSearch": true,
      "includeWorkflowAnalysis": true
    },
    "research_phase_options": {
      "depth": 5,
      "enrich": true,
      "includeStandardFields": true,
      "includeCMTSearch": true,
      "includeWorkflowAnalysis": true
    },
    "deep_analysis_options": {
      "depth": 8,
      "enrich": true,
      "includeStandardFields": true,
      "includeCMTSearch": true,
      "includeWorkflowAnalysis": true,
      "description": "Use for complex objects with many dependencies or when full picture is needed"
    },
    "cli_flags": {
      "--depth": "Recursion depth for dependency traversal (default: 5 for research)",
      "--enrich": "Enable usage enrichment with context pills",
      "--include-standard-fields": "Scan code for standard field references",
      "--include-cmt-search": "Search CMT string fields for class/field references",
      "--include-workflow-analysis": "Analyze workflow rules and field updates",
      "--all-enhanced": "Enable all enhanced features (default for research phase)",
      "--output-path": "Save detailed JSON to specified path (required for research)"
    },
    "pills": {
      "description": "Context indicators attached to usage items",
      "types": [
        { "label": "Read", "context": "Used for reading data", "severity": "info" },
        { "label": "Write", "context": "Used for writing/updating data", "severity": "warning" },
        { "label": "Filter", "context": "Used in report filters", "severity": "info" },
        { "label": "Grouping", "context": "Used in report groupings", "severity": "info" },
        { "label": "CMT Reference", "context": "Referenced in Custom Metadata Type", "severity": "info" },
        { "label": "Validation", "context": "Used in validation rule", "severity": "warning" },
        { "label": "Active", "context": "Component is active", "severity": "success" },
        { "label": "Inactive", "context": "Component is inactive", "severity": "neutral" }
      ]
    }
  },
  "organizational_context": {
    "file": "#file:.github/config/umgc-organizational-context.json",
    "documentation": "#file:.github/docs/umgc-organizational-context.md"
  }
}

